# Copy to .env and fill in your credentials.
# .env is gitignored — never commit real secrets.

# X (Twitter) account credentials — only needed if you use the legacy twikit
# x_client.XClient. The Nitter-RSS based x_client_web.XClientWeb (default) and
# the Reddit-backed /snsbuzz both work without credentials.
X_USERNAME=
X_USER_MAIL=
X_USER_PASSWORD=

# Telegram bot for notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
